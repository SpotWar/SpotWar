# Supabase client config for the app, read at bundle time by Expo.
# Only EXPO_PUBLIC_-prefixed vars are exposed to the client bundle.
#
# Copy this file to app/.env (gitignored) and adjust if needed. The values below
# are the defaults printed by `npx supabase start` for the local stack — the
# anon key is the standard local-dev demo key, so it is safe to commit here.

EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
