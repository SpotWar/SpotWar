# --- Mock Strava server (mock-strava/) -------------------------------------

# Flip the SPOTWAR Edge Functions between the mock and the real Strava API.
# When 'true', STRAVA_BASE_URL resolves to http://localhost:3000 (this server);
# otherwise https://www.strava.com. No code changes needed to switch.
STRAVA_MOCK=true

# Port this mock server listens on (Strava base when STRAVA_MOCK=true).
PORT=3000

# Where POST /simulate-webhook delivers the fake Strava webhook event.
# Default points at the local Supabase Edge Function webhook receiver.
WEBHOOK_TARGET_URL=http://localhost:54321/functions/v1/strava-webhook

# Local Supabase anon key, forwarded as the Bearer token on /simulate-webhook
# (Edge Functions require an Authorization header). Get it from `supabase status`.
SUPABASE_ANON_KEY=
